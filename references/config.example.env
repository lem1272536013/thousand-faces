# GENERATED FILE - edit scripts/settings.py, then run:
#   python scripts/generate_config_docs.py
# Profile: generic
# Intentional difference from .env.example: generic Settings defaults are used; no TikHub endpoint preset is applied.
# Copy to .env for a live run; never place real credentials in this template.

# --- TikHub collection ---

# TikHub API credential.
# Metadata: string, optional; standard, active, secret
TIKHUB_API_KEY=

# TikHub absolute HTTP API base URL.
# Metadata: string, optional; standard, active
TIKHUB_API_BASE=

# TikHub creator-video relative endpoint path.
# Metadata: string, optional; standard, active
TIKHUB_CREATOR_VIDEOS_ENDPOINT=

# TikHub authentication header name.
# Metadata: string; advanced, active
TIKHUB_AUTH_HEADER=Authorization

# TikHub authentication scheme.
# Metadata: string; advanced, active
TIKHUB_AUTH_SCHEME=Bearer

# Maximum metadata items requested.
# Metadata: integer [1..5000]; standard, active
TIKHUB_METADATA_FETCH_LIMIT=100

# TikHub source URL query parameter.
# Metadata: string; standard, active
TIKHUB_SOURCE_URL_PARAM=url

# Resolve Douyin share URLs before TikHub calls.
# Metadata: boolean; standard, active
TIKHUB_AUTO_RESOLVE_DOUYIN_URL=true

# TikHub item-limit query parameter.
# Metadata: string; standard, active
TIKHUB_LIMIT_PARAM=limit

# Additional TikHub query string.
# Metadata: string, optional; advanced, active
TIKHUB_EXTRA_QUERY=

# Optional dotted TikHub item-list path.
# Metadata: string, optional; advanced, active
TIKHUB_ITEMS_PATH=

# Optional dotted TikHub video ID path.
# Metadata: string, optional; advanced, active
TIKHUB_VIDEO_ID_PATH=

# Optional dotted TikHub title path.
# Metadata: string, optional; advanced, active
TIKHUB_VIDEO_TITLE_PATH=

# Optional dotted TikHub publish-time path.
# Metadata: string, optional; advanced, active
TIKHUB_VIDEO_PUBLISHED_AT_PATH=

# Optional dotted TikHub download URL path.
# Metadata: string, optional; advanced, active
TIKHUB_VIDEO_DOWNLOAD_URL_PATH=

# Optional dotted TikHub source URL path.
# Metadata: string, optional; advanced, active
TIKHUB_VIDEO_SOURCE_URL_PATH=

# TikHub pagination cursor field and query parameter.
# Metadata: string; standard, active
TIKHUB_CURSOR_PARAM=max_cursor

# Enable bounded TikHub cursor pagination.
# Metadata: boolean; standard, active
TIKHUB_ENABLE_PAGINATION=true

# Maximum TikHub pages per metadata request.
# Metadata: integer [1..1000]; standard, active
TIKHUB_MAX_PAGES=20

# --- ASR and audio ---

# ASR provider adapter selection.
# Metadata: enum (openai-compatible, compatible, qwen-compatible, aliyun); standard, active
ALI_ASR_PROVIDER=openai-compatible

# ASR provider credential.
# Metadata: string, optional; standard, active, secret
ALI_ASR_API_KEY=

# OpenAI-compatible ASR absolute endpoint.
# Metadata: string, optional; standard, active
ALI_ASR_ENDPOINT=

# ASR model identifier.
# Metadata: string; standard, active
ALI_ASR_MODEL=qwen3-asr-flash

# ASR language hint.
# Metadata: string; standard, active
ALI_ASR_LANGUAGE=zh-CN

# Extracted audio container suffix.
# Metadata: string; advanced, active
ALI_ASR_AUDIO_FORMAT=mp3

# Compatible ASR response format.
# Metadata: string; advanced, active
ALI_ASR_RESPONSE_FORMAT=json

# Compatible ASR audio MIME type.
# Metadata: string; advanced, active
ALI_ASR_MIME_TYPE=audio/mpeg

# Compatible ASR request style.
# Metadata: enum (chat-completions, audio-transcriptions); advanced, active
ALI_ASR_COMPATIBLE_API=chat-completions

# Enable inverse text normalization when supported.
# Metadata: boolean; advanced, active
ALI_ASR_ENABLE_ITN=false

# ASR request timeout in seconds.
# Metadata: integer [1..3600]; advanced, active
ALI_ASR_TIMEOUT_SECONDS=180

# Maximum concurrent ASR video tasks.
# Metadata: integer [1..16]; standard, active
ALI_ASR_CONCURRENCY=4

# Maximum raw compatible-chat audio bytes per request.
# Metadata: integer [1..33554432]; advanced, active
ALI_ASR_MAX_BASE64_AUDIO_BYTES=8388608

# Legacy ASR retry attempts.
# Metadata: integer [1..20]; advanced, deprecated; use PROVIDER_RETRY_MAX_ATTEMPTS
# ALI_ASR_RETRY=3

# DashScope polling interval in seconds.
# Metadata: float [0.1..3600]; advanced, active
ALI_ASR_POLL_SECONDS=5

# DashScope polling deadline in seconds.
# Metadata: float [1..86400]; advanced, active
ALI_ASR_POLL_DEADLINE_SECONDS=900

# Legacy bounded DashScope waiting mode.
# Metadata: enum (wait, poll); advanced, active
ALI_ASR_WAIT_MODE=wait

# Absolute public audio URL template for file-url ASR.
# Metadata: string, optional; advanced, active
ALI_ASR_AUDIO_URL_TEMPLATE=

# Absolute public audio base URL.
# Metadata: string, optional; advanced, active
AUDIO_PUBLIC_URL_BASE=

# Audio sample rate in hertz.
# Metadata: integer [8000..384000]; advanced, active
ASR_SAMPLE_RATE=16000

# FFmpeg MP3 audio bitrate.
# Metadata: string; advanced, active
ASR_MP3_BITRATE=64k

# Maximum ASR segment duration in seconds.
# Metadata: integer [1..3600]; advanced, active
ASR_SEGMENT_SECONDS=120

# DashScope API credential.
# Metadata: string, optional; standard, active, secret
DASHSCOPE_API_KEY=

# DashScope-compatible absolute HTTP API base URL.
# Metadata: string, optional; standard, active
DASHSCOPE_BASE_HTTP_API_URL=

# --- OSS temporary audio ---

# Aliyun OSS endpoint.
# Metadata: string, optional; advanced, active
ALI_OSS_ENDPOINT=

# Aliyun OSS bucket name.
# Metadata: string, optional; advanced, active
ALI_OSS_BUCKET=

# Aliyun OSS access-key identifier.
# Metadata: string, optional; advanced, active, secret
ALI_OSS_ACCESS_KEY_ID=

# Aliyun OSS access-key secret.
# Metadata: string, optional; advanced, active, secret
ALI_OSS_ACCESS_KEY_SECRET=

# Managed OSS object prefix.
# Metadata: string; advanced, active
ALI_OSS_PREFIX=creator-agent-studio/audio

# OSS signed URL lifetime in seconds.
# Metadata: integer [60..3600]; advanced, active
ALI_OSS_SIGNED_URL_EXPIRES=3600

# Temporary OSS audio lifecycle mode.
# Metadata: enum (delete_after_asr, retain); advanced, active
ALI_OSS_LIFECYCLE_POLICY=delete_after_asr

# Failed ASR OSS retention window in seconds.
# Metadata: integer [60..2592000]; advanced, active
ALI_OSS_FAILURE_RETENTION_SECONDS=86400

# --- Provider recovery ---

# Unified provider maximum attempts.
# Metadata: integer [1..20]; advanced, active
PROVIDER_RETRY_MAX_ATTEMPTS=3

# Unified provider base backoff.
# Metadata: float [0..3600]; advanced, active
PROVIDER_RETRY_BASE_SECONDS=1

# Unified provider maximum backoff.
# Metadata: float [0..3600]; advanced, active
PROVIDER_RETRY_MAX_SECONDS=10

# Unified provider retry jitter ratio.
# Metadata: float [0..1]; advanced, active
PROVIDER_RETRY_JITTER_RATIO=0.2

# Unified logical request deadline.
# Metadata: float [0.1..3600]; advanced, active
PROVIDER_REQUEST_DEADLINE_SECONDS=300

# --- Local runtime ---

# Default root directory for new runs.
# Metadata: string; standard, active
RUN_ROOT=runs

# Maximum concurrent video downloads.
# Metadata: integer [1..32]; standard, active
DOWNLOAD_CONCURRENCY=6

# Video download retry attempts.
# Metadata: integer [1..20]; standard, active
DOWNLOAD_RETRY=3

# Maximum bytes per downloaded video.
# Metadata: integer [1..53687091200]; standard, active
MAX_VIDEO_BYTES=536870912

# Download response-header timeout.
# Metadata: integer [1..3600]; advanced, active
DOWNLOAD_HEADER_TIMEOUT_SECONDS=30

# Total video download deadline.
# Metadata: integer [1..3600]; advanced, active
DOWNLOAD_DEADLINE_SECONDS=300

# ffprobe media-validation timeout.
# Metadata: integer [1..3600]; advanced, active
MEDIA_PROBE_TIMEOUT_SECONDS=30

# Default provider request timeout.
# Metadata: integer [1..3600]; advanced, active
HTTP_TIMEOUT_SECONDS=60

# FFmpeg executable name or path.
# Metadata: string; advanced, active
FFMPEG_BIN=ffmpeg

# Maximum concurrent FFmpeg processes.
# Metadata: integer [1..8]; standard, active
FFMPEG_CONCURRENCY=2

# ffprobe executable name or path.
# Metadata: string; advanced, active
FFPROBE_BIN=ffprobe

# --- Quality thresholds ---

# Minimum draft stage count.
# Metadata: integer [1..1000]; advanced, active
DRAFT_MIN_STAGE_COUNT=2

# Minimum draft stage ratio.
# Metadata: float [0.01..1]; advanced, active
DRAFT_MIN_STAGE_RATIO=0.8

# Minimum ready stage count.
# Metadata: integer [1..1000]; advanced, active
READY_MIN_STAGE_COUNT=5

# Minimum ready stage ratio.
# Metadata: float [0.01..1]; advanced, active
READY_MIN_STAGE_RATIO=0.95
