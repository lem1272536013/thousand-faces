# Thousand Faces environment template
#
# Copy this file to `.env` before a live run:
#
#   copy .env.example .env
#
# `.env` contains secrets and is intentionally ignored by git.


# ============================================================================
# Required for live collection: TikHub
# ============================================================================

TIKHUB_API_KEY=
TIKHUB_API_BASE=https://api.tikhub.io
TIKHUB_CREATOR_VIDEOS_ENDPOINT=/api/v1/douyin/app/v3/fetch_user_post_videos


# ============================================================================
# Required for live transcription: Qwen-ASR OpenAI-compatible mode
# ============================================================================

ALI_ASR_PROVIDER=openai-compatible

# Fill one of these. `ALI_ASR_API_KEY` is preferred by this project.
ALI_ASR_API_KEY=
DASHSCOPE_API_KEY=

# Fill one of these. Use the base endpoint that serves `/chat/completions`.
ALI_ASR_ENDPOINT=
DASHSCOPE_BASE_HTTP_API_URL=

ALI_ASR_MODEL=qwen3-asr-flash


# ============================================================================
# Common optional settings
# ============================================================================

# TikHub auth and query parameters.
TIKHUB_AUTH_HEADER=Authorization
TIKHUB_AUTH_SCHEME=Bearer
TIKHUB_METADATA_FETCH_LIMIT=100
TIKHUB_SOURCE_URL_PARAM=sec_user_id
TIKHUB_AUTO_RESOLVE_DOUYIN_URL=true
TIKHUB_LIMIT_PARAM=count
TIKHUB_EXTRA_QUERY=max_cursor=0&sort_type=0

# ASR defaults.
ALI_ASR_LANGUAGE=zh-CN
ALI_ASR_AUDIO_FORMAT=mp3
ALI_ASR_RESPONSE_FORMAT=json
ALI_ASR_MIME_TYPE=audio/mpeg
ALI_ASR_COMPATIBLE_API=chat-completions
ALI_ASR_ENABLE_ITN=false
ALI_ASR_TIMEOUT_SECONDS=180
ALI_ASR_CONCURRENCY=4

# Local runtime defaults.
RUN_ROOT=runs
DOWNLOAD_CONCURRENCY=6
DOWNLOAD_RETRY=3
HTTP_TIMEOUT_SECONDS=60
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
ASR_SAMPLE_RATE=16000
ASR_MP3_BITRATE=64k
ASR_SEGMENT_SECONDS=120


# ============================================================================
# Advanced: TikHub response mapping
# ============================================================================
#
# Only set these when automatic metadata normalization cannot infer fields from
# your TikHub response.

TIKHUB_ITEMS_PATH=
TIKHUB_VIDEO_ID_PATH=
TIKHUB_VIDEO_TITLE_PATH=
TIKHUB_VIDEO_PUBLISHED_AT_PATH=
TIKHUB_VIDEO_DOWNLOAD_URL_PATH=
TIKHUB_VIDEO_SOURCE_URL_PATH=


# ============================================================================
# Advanced: DashScope recorded-file ASR / public audio URL / OSS bridge
# ============================================================================
#
# Usually not needed when `ALI_ASR_PROVIDER=openai-compatible`.
# Needed only when the ASR provider requires a publicly accessible audio URL.

ALI_ASR_APP_KEY=
ALI_ASR_POLL_SECONDS=5
ALI_ASR_WAIT_MODE=wait
ALI_ASR_AUDIO_URL_TEMPLATE=
AUDIO_PUBLIC_URL_BASE=

ALI_OSS_ENDPOINT=
ALI_OSS_BUCKET=
ALI_OSS_ACCESS_KEY_ID=
ALI_OSS_ACCESS_KEY_SECRET=
ALI_OSS_PREFIX=creator-agent-studio/audio
ALI_OSS_SIGNED_URL_EXPIRES=3600


# ============================================================================
# Advanced: host-agent research budget hints
# ============================================================================

MAX_INPUT_TOKENS=120000
MAX_OUTPUT_TOKENS=8000
AUTO_RESUME=true
